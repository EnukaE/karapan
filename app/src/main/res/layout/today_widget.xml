<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📅 Today's Focus"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_badge_bg"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="1.5dp"
            android:paddingBottom="1.5dp"
            android:text="0 pending"
            android:textColor="#1B5E20"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E3E34"
        android:layout_marginBottom="8dp"/>

    <!-- Empty text -->
    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="All focus tasks completed! 🎉"
        android:textColor="#81C784"
        android:textSize="11sp"
        android:visibility="gone"
        android:layout_marginTop="12dp"/>

    <!-- Items container -->
    <LinearLayout
        android:id="@+id/widget_items_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Item 1 -->
        <LinearLayout
            android:id="@+id/widget_item_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▪ "
                android:textColor="#81C784"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/widget_item_text_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No task"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 2 -->
        <LinearLayout
            android:id="@+id/widget_item_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▪ "
                android:textColor="#81C784"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/widget_item_text_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No task"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 3 -->
        <LinearLayout
            android:id="@+id/widget_item_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▪ "
                android:textColor="#81C784"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/widget_item_text_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No task"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Item 4 -->
        <LinearLayout
            android:id="@+id/widget_item_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▪ "
                android:textColor="#81C784"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/widget_item_text_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No task"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
